DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============ 支付宝支付配置 ============
# 获取方式：https://open.alipay.com → 开发者中心 → 创建应用
# 沙箱环境：https://openhome.alipay.com/develop/sandbox/app

# 应用 APPID
ALIPAY_APP_ID=

# 应用私钥（一长串 base64，含 BEGIN/END 头尾）
# 注意：换行用 \n 转义
ALIPAY_PRIVATE_KEY=

# 支付宝公钥（用于验签）
ALIPAY_PUBLIC_KEY=

# 是否沙箱环境（true=沙箱，false=正式）
ALIPAY_SANDBOX=true

# 网站基础 URL（用于支付回调地址）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
