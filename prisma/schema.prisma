// AI 写小说平台 - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ 用户与计费 ============
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   // scrypt 哈希
  name         String?
  penName      String?
  avatar       String?
  tokens       Int      @default(10000) // Token 余额
  plan         String   @default("free") // free / pro / year
  role         String   @default("user") // user / admin
  banned       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  folders      Folder[]
  novels       Novel[]
  characters   Character[]
  worldviews   Worldview[]
  items        Item[]
  chatMessages ChatMessage[]
  dailyStats   DailyStat[]
  orders       Order[]
  autoSerials  AutoSerial[]
}

// 充值订单
model Order {
  id        String    @id @default(cuid())
  userId    String
  amount    Float     // 金额（元）
  tokens    Int       // 购买的 Token 数
  status    String    @default("pending") // pending / paid / failed
  method    String    @default("alipay") // alipay / wechat / card
  createdAt DateTime  @default(now())
  paidAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// AI 自动连载任务
model AutoSerial {
  id             String   @id @default(cuid())
  novelId        String
  userId         String
  enabled        Boolean  @default(true)
  intervalMin    Int      @default(60) // 每次生成间隔（分钟）
  targetWords    Int      @default(2000) // 每章目标字数
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  status         String   @default("idle") // idle / running / paused / error
  totalGenerated Int      @default(0) // 已自动生成章节数
  lastError      String?
  plotDirection  String?  // 剧情走向提示（用户给 AI 的方向）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  novel          Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 每日创作统计 (热力图用)
model DailyStat {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  words     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ============ 文件夹管理 ============
model Folder {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("slate")
  sortOrder Int      @default(0)
  userId    String
  parentId  String?  // 支持多级文件夹
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  novels    Novel[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ 小说 ============
model Novel {
  id          String        @id @default(cuid())
  title       String
  cover       String?
  author      String?
  genre       String        @default("玄幻")
  tags        String        @default("")
  synopsis    String?
  outline     String?
  status      String        @default("ongoing") // ongoing / completed / hiatus
  totalWords  Int           @default(0)
  folderId    String?
  folder      Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  volumes     Volume[]
  chapters    Chapter[]
  autoSerials AutoSerial[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// 卷
model Volume {
  id        String   @id @default(cuid())
  title     String
  sortOrder Int      @default(0)
  isOutline Boolean  @default(false)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapters  Chapter[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 章节/节
model Chapter {
  id         String   @id @default(cuid())
  title      String
  content    String   @default("")
  summary    String?
  words      Int      @default(0)
  status     String   @default("draft") // draft / polishing / final
  sortOrder  Int      @default(0)
  autoGen    Boolean  @default(false) // 是否由 AI 自动连载生成
  volumeId   String
  volume     Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  novelId    String
  novel      Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============ 设定库 ============
model Character {
  id         String   @id @default(cuid())
  name       String
  avatar     String?
  appearance String?
  personality String?
  background String?
  abilities  String?
  relations  String?
  novelId    String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Worldview {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("geography")
  description String?
  novelId     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Item {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("item")
  attributes  String?
  effect      String?
  novelId     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ AI 对话历史 ============
model ChatMessage {
  id         String   @id @default(cuid())
  role       String   // user / assistant / system
  content    String
  preset     String?
  novelId    String?
  chapterId  String?
  tokensUsed Int      @default(0)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ============ 邮件系统 ============
// 管理员配置的 SMTP 邮箱（单条记录，全局唯一）
model EmailConfig {
  id           String   @id @default(cuid())
  // SMTP 配置
  smtpHost     String   // 如 smtp.163.com
  smtpPort     Int      @default(465)
  smtpSecure   Boolean  @default(true) // 465 为 true，587 为 false
  smtpUser     String   // 邮箱地址
  smtpPass     String   // 邮箱密码或授权码
  fromName     String   @default("墨灵写作") // 发件人显示名
  // 状态
  enabled      Boolean  @default(true)
  lastTestAt   DateTime?
  lastTestOk   Boolean  @default(false)
  lastTestErr  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 邮箱验证码（用于注册、找回密码等场景）
model EmailCode {
  id        String   @id @default(cuid())
  email     String   // 接收邮箱
  code      String   // 6 位验证码
  purpose   String   @default("register") // register / reset / login
  expired   Boolean  @default(false)
  used      Boolean  @default(false)
  expiresAt DateTime // 过期时间
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

// ============ 兑换码系统 ============
// 兑换码（管理员生成）
model RedeemCode {
  id          String    @id @default(cuid())
  code        String    @unique // 兑换码（大写字母+数字）
  // 奖励类型
  rewardType  String    // token / plan
  // token 奖励
  tokenAmount Int       @default(0) // 当 rewardType=token 时有效
  // 会员奖励
  planReward  String?   // pro / year，当 rewardType=plan 时有效
  planDays    Int       @default(0) // 会员天数（如 30 天月卡）
  // 批次信息
  batchId     String?   // 批次 ID（同一次生成的归为一批）
  batchNote   String?   // 批次备注（如「双十一活动」）
  // 状态
  status      String    @default("unused") // unused / used / disabled
  usedBy      String?   // 使用者 userId
  usedAt      DateTime?
  expiresAt   DateTime? // 兑换码过期时间（null 表示永久）
  // 创建信息
  createdById String    // 创建管理员 id
  createdAt   DateTime  @default(now())

  history     RedeemHistory[]

  @@index([batchId])
  @@index([status])
}

// 兑换历史记录
model RedeemHistory {
  id        String   @id @default(cuid())
  codeId    String
  code      String   // 冗余存储兑换码字符串
  userId    String
  // 兑换时的奖励快照
  rewardType String
  tokenAmount Int
  planReward  String?
  planDays    Int
  // 兑换前后的余额
  tokensBefore Int
  tokensAfter  Int
  planBefore   String
  planAfter    String
  redeemedAt   DateTime @default(now())

  redeemCode RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@index([userId])
}
